<?xml version='1.0' encoding='utf-8'?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>
        <!-- Настройки подключения к базе данных -->
        <property name="hibernate.connection.driver_class">com.mysql.cj.jdbc.Driver</property>
        <!-- В конце URL обязательно добавь название базы данных, например /test -->
        <property name="hibernate.connection.url">jdbc:mysql://localhost:3306/test</property>
        <property name="hibernate.connection.username">root</property>
        <property name="hibernate.connection.password">admin</property>

        <!-- Настройки диалекта (для MySQL 8.x лучше использовать этот) -->
        <property name="hibernate.dialect">org.hibernate.dialect.MySQLDialect</property>

        <!-- Показывать SQL-запросы в консоли -->
        <property name="show_sql">true</property>
        <property name="hibernate.format_sql">true</property>

        <!-- Автоматическое обновление таблиц при запуске (очень удобно для обучения) -->
        <property name="hibernate.hbm2ddl.auto">update</property>

        <!-- Регистрация твоего класса-сущности -->
        <mapping class="Les_4_DBAndTools.Magic"/></session-factory></hibernate-configuration>
